<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">
    <link rel="icon" type="image/png" href="/images/logo.png">
    <title>Task Editor</title>
</head>
<body>
    <%- include('partials/header') %>

    <h2>Aufgabe bearbeiten</h2>

<form action="/tasks/update/<%= task._id %>" method="POST">

    <label>Person:
        <select name="person">
            <% persons.forEach(p => { %>
                <option value="<%= p.person %>"
                    <%= p.person === task.person ? 'selected' : '' %>>
                    <%= p.person %>
                </option>
            <% }) %>
        </select>
    </label>

    <label>Datum:
        <input type="date" name="date"
               value="<%= task.date.toISOString().split('T')[0] %>">
    </label>

    <label>Typ:
        <select name="type">
            <option value="">-- Eigenständig --</option>
            <% reminders.forEach(r => { %>
                <option value="<%= r.name %>"
                    <%= r.name === task.type ? 'selected' : '' %>>
                    <%= r.name %>
                </option>
            <% }) %>
        </select>
    </label>

    <label>Uhrzeit:
        <input type="time" name="clock"
            value="<%= task.hour != null ? 
                String(task.hour).padStart(2,'0') + ':' + 
                String(task.minute).padStart(2,'0') 
                : '' %>">
    </label>

    <label>Content:
        <input type="text" name="content"
               value="<%= task.content || '' %>">
    </label>

    <button type="submit">Speichern</button>
</form>
<a href="/tasks"><button type="button">Abbrechen</button></a>
</body>
</html>