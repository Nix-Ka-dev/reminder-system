<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.simplecss.org/simple.min.css">
    <link rel="icon" type="image/png" href="/images/logo.png">

    <title>Scheduled Tasks</title>
    <style>
        .hidden { display: none; }
    </style>
</head>
<body>
    <%- include('partials/header') %>

    <h3>Aufgabenverwaltung</h3>
<details>
    <summary>Neue Aufgabe erstellen</summary>

<form action="/tasks" method="POST">
    <label>
        <input type="checkbox" id="independent" name="independent">
        Eigenständig
    </label>

    <div id="common-fields">
        <label>Person: 
            <select name="person">
                <option value="">-- auswählen --</option>
                <% persons.forEach(person => { %>
                <option value="<%= person.person %>"><%= person.person %></option>
                <% }) %>
            </select>
        </label>

        <label>Datum: <input type="date" name="date" required></label>
    </div>

    <div id="type-field">
        <label>Typ: 
            <select name="type">
                <option value="">-- auswählen --</option>
                <% reminders.forEach(reminder => { %>
                <option value="<%= reminder.name %>"><%= reminder.name %></option>
                <% }) %>
            </select>
        </label>
    </div>

    <div id="independent-fields" class="hidden">
        <label>Uhrzeit: <input type="time" name="clock"></label>
        <label>Content: <input type="text" name="content"></label>
    </div>

    <button type="submit">Speichern</button>
</form>
</details>
<hr>
<details>
<summary>Aufgaben Generator</summary>

<form action="/tasks/generate" method="POST">
    <label>Startdatum:
        <input type="date" name="startDate" required>
    </label>

    <label>Enddatum:
        <input type="date" name="endDate" required>
    </label>

    <label>Typ:
        <select name="type" required>
            <option value="">-- auswählen --</option>
            <% reminders.forEach(r => { %>
                <option value="<%= r.name %>"><%= r.name %></option>
            <% }) %>
        </select>
    </label>
    <label>Tage auswählen:</label><br>

<label><input type="checkbox" name="days" value="1"> Montag</label>
<label><input type="checkbox" name="days" value="2"> Dienstag</label>
<label><input type="checkbox" name="days" value="3"> Mittwoch</label>
<label><input type="checkbox" name="days" value="4"> Donnerstag</label>
<label><input type="checkbox" name="days" value="5"> Freitag</label>
<label><input type="checkbox" name="days" value="6"> Samstag</label>
<label><input type="checkbox" name="days" value="0"> Sonntag</label>

    <button type="submit">Zeitraum generieren</button>
</form>
</details>


    <h3>Gespeicherte Aufgaben:</h3>
<table>
    <thead>
        <tr>
            <th>Person</th>
            <th>Datum</th>
            <th>Typ</th>
            <th>Uhrzeit</th>
            <th>Content</th>
            <th>Aktionen</th>

        </tr>
    </thead>
    <tbody>
        <% tasks.forEach(task => { %>
        <tr>
            <td><%= task.person %></td>
            <td><%= task.date.toLocaleDateString('de-DE') %></td>

            <td><%= task.type || '-' %></td>
            <td>
                <% if (task.hour != null && task.minute != null) { %>
                    <%= String(task.hour).padStart(2,'0') %>:<%= String(task.minute).padStart(2,'0') %>
                <% } else { %>
                    -
                <% } %>
            </td>
            <td><%= task.content || '-' %></td>
            <td>

    <a href="/tasks/edit/<%= task._id %>">
        <button type="button">Bearbeiten</button>
    </a>
    <form style="margin-right: 8px;" action="/tasks/delete/<%= task._id %>" method="POST" 
          onsubmit="return confirm('Wirklich löschen?')">
        <button type="submit">Löschen</button>
    </form>
</td>

        </tr>
        <% }) %>
    </tbody>
</table>


    <script>
        const checkbox = document.getElementById("independent");
        const independentFields = document.getElementById("independent-fields");
        const typeField = document.getElementById("type-field");

        checkbox.addEventListener("change", () => {
            if (checkbox.checked) {
                // Eigenständig = Uhrzeit & Content zeigen, Typ verstecken
                independentFields.classList.remove("hidden");
                typeField.classList.add("hidden");
            } else {
                // Nicht eigenständig = Typ zeigen, Uhrzeit & Content verstecken
                independentFields.classList.add("hidden");
                typeField.classList.remove("hidden");
            }
        });
    </script>
    <style>
        td form {
    display: inline-block;
    margin: 0;
}

td a {
    display: inline-block;
    margin: 0;
}

td {
    white-space: nowrap;
}

    </style>
</body>
</html>
